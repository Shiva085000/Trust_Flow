# ---------------------------------------------------------------------------
# LLM backend — set ONE of the two options below
# ---------------------------------------------------------------------------

# Option A: Groq cloud (llama-3.3-70b-versatile is the default model)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Option B: Local vLLM server (used automatically when GROQ_API_KEY is unset)
VLLM_BASE_URL=http://localhost:8000/v1
VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
DATABASE_URL=sqlite:///./hackstrom.db

# ---------------------------------------------------------------------------
# File storage
# ---------------------------------------------------------------------------
UPLOAD_DIR=/tmp/hackstrom_uploads
